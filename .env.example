# Copy to .env and fill in secrets:
#   cp .env.example .env
#
# Or generate Postgres/Redis credentials automatically:
#   ./scripts/setup-env.sh

COMPOSE_PROJECT_NAME=tvtime2serializd

# ── Infrastructure (Docker Compose) ─────────────────────────────────────────

POSTGRES_USER=tvtime
POSTGRES_PASSWORD=
POSTGRES_DB=tvtime2serializd
POSTGRES_HOST_PORT=5433

REDIS_PASSWORD=
REDIS_HOST_PORT=6380

# ── API server ────────────────────────────────────────────────────────────────

API_HOST_PORT=8080
PORT=8080

# Connection strings used by the API and migrate services inside Docker.
# setup-env.sh fills these from the credentials above.
DATABASE_URL=
REDIS_URL=

# AES-256 key for encrypting stored TV Time / Serializd tokens (32 bytes, base64).
# Generate: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
#           openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Comma-separated browser origins allowed to call the API (CORS).
# Example: https://app.example.com,https://www.example.com
# Leave empty to disable cross-origin access (same-origin / server-to-server only).
CORS_ALLOWED_ORIGINS=

# Trusted reverse proxies in front of the API (nginx = 1). Set to 0 for direct exposure.
TRUSTED_PROXY_COUNT=1

# Optional TMDB API key (Bearer token) for TVDB → TMDB fallback lookup.
TMDB_API_KEY=

# Optional dev defaults when login request bodies omit credentials (not for production).
TVTIME_EMAIL=
TVTIME_PASSWORD=
SERIALIZD_EMAIL=
SERIALIZD_PASSWORD=

# ── Migration tuning ──────────────────────────────────────────────────────────

# Parallelism (defaults: gather=24, lookup=32, import=8; max 64 each)
TVTIME_GATHER_CONCURRENCY=24
MIGRATE_LOOKUP_CONCURRENCY=32
MIGRATE_IMPORT_CONCURRENCY=8

# Max migrations running at once (FIFO queue; default 4, max 5)
MIGRATE_QUEUE_CONCURRENCY=4

# Global outbound HTTP concurrency per external service (shared across all jobs).
OUTBOUND_TVTIME_MAX=24
OUTBOUND_SERIALIZD_MAX=12
OUTBOUND_WIKIDATA_MAX=8
OUTBOUND_TMDB_MAX=8

# Credential endpoint rate limits (per client IP)
RATE_LIMIT_CREDENTIAL_RPM=6
RATE_LIMIT_CREDENTIAL_BURST=3

# ── Advanced (optional) ─────────────────────────────────────────────────────

# Postgres pool size (default: driver default)
# DATABASE_MAX_CONNS=10

# Verbose TMDB lookup logging (set to 1 to enable)
# TMDB_LOOKUP_DEBUG=0
